# Finnhub — real-time quotes & WebSocket streaming
# Get free key at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Polygon.io — options chain + Greeks
# Get key at https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Alpaca — broker integration (read-only portfolio, manual order confirmation)
# Paper trading keys from https://app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Telegram bot for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS origins for Next.js dev server
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
