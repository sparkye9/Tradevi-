# Finviz Elite — auto-login using your account credentials
FINVIZ_EMAIL=your_finviz_email@example.com
FINVIZ_PASSWORD=your_finviz_password

# Optional: hard-code an already-obtained session cookie to skip the login step.
# If set, this takes priority over email/password.
# FINVIZ_SESSION_COOKIE=

# Tradier API — options greeks (production or sandbox)
TRADIER_TOKEN=your_tradier_api_token
TRADIER_ENV=production
