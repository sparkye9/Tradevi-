# TradeWise Environment Variables
# Copy this file to .env.local and fill in your values

# App Settings
NEXT_PUBLIC_APP_NAME=TradeWise
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=30

# Optional: Cache TTL in seconds for market data
QUOTE_CACHE_TTL=15
CHART_CACHE_TTL=60
OPTIONS_CACHE_TTL=30
SCANNER_CACHE_TTL=60

# DISCLAIMER: This app does not provide financial advice.
# All data is for educational and research purposes only.
# Always confirm trades manually in your brokerage.
