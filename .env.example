# Tradevi Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Backend URL ─────────────────────────────────────────────────────────────
# URL of the FastAPI backend for real-time market data
# This is critical: the backend handles all API keys securely and routes data through
# market data providers (Finnhub for real-time quotes and candles)
# DO NOT leave blank in production — backend provides superior data quality
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── API Keys ────────────────────────────────────────────────────────────────
# Finnhub API key for market data
# Get FREE key at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Polygon.io API key — fallback options chain data source when Yahoo is unavailable
# Free key at https://polygon.io (includes 15-min delayed options data + Greeks)
# Paid plans unlock real-time data
POLYGON_API_KEY=your_polygon_api_key_here

# ─── App settings ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Tradevi

# ─── SECURITY NOTICE ─────────────────────────────────────────────────────────
# ⚠️  NEVER add API keys directly to this file.
# ⚠️  API keys must ONLY be configured in backend/.env (see backend/.env.example)
# ⚠️  The backend proxies all API requests — frontend never touches API keys.
# ⚠️  If you see API errors or "Market data unavailable", check backend/.env

# ─── DISCLAIMER ──────────────────────────────────────────────────────────────
# This app does not provide financial advice.
# All data is for educational and research purposes only.
# Always confirm trades manually in your brokerage.
# This app NEVER places trades automatically.
