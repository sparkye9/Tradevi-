# Tradevi Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Backend URL ─────────────────────────────────────────────────────────────
# URL of the FastAPI backend (see backend/.env.example for backend config)
# Leave blank to use the built-in Next.js API routes (Yahoo Finance only, delayed)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── App settings ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Tradevi

# ─── DISCLAIMER ──────────────────────────────────────────────────────────────
# This app does not provide financial advice.
# All data is for educational and research purposes only.
# Always confirm trades manually in your brokerage.
# This app NEVER places trades automatically.
